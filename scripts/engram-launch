#!/bin/bash
# Launcher used by the plugin's .mcp.json and hooks. Usage: engram-launch {mcp|hook} [...]
#
# Prefers the uv path (pulls fastembed + the embedding model on first run → full
# SEMANTIC recall, the default), and falls back to the committed self-contained
# binary (TEXT recall, zero setup) on machines without uv.
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"
BIN="$ROOT/bin/${OS}_${ARCH}/engram"

SUB="${1:-}"; shift || true

# 1) uv present → semantic-capable path (deps + model pulled on demand, then offline).
if command -v uv >/dev/null 2>&1; then
  case "$SUB" in
    mcp)  exec uv run --directory "$ROOT" engram-mcp ;;
    hook) exec uv run --directory "$ROOT" engram-hook "$@" ;;
  esac
fi

# 2) no uv → lean self-contained binary (text recall, zero setup).
if [ -x "$BIN" ]; then
  exec "$BIN" "$SUB" "$@"
fi

echo "engram: install uv for semantic recall (https://docs.astral.sh/uv/) or run scripts/build_binary.sh" >&2
exit 127
